{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/dev/claude-block-sensitive.sh",
            "statusMessage": "Checking for sensitive files"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/dev/claude-check-workspace-clippy.sh",
            "timeout": 120,
            "statusMessage": "Running clippy"
          }
        ]
      }
    ]
  }
}
