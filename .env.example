# Conary project environment variables
# Copy to .env and fill in values. Never commit .env.

# Remi admin API token (generate via: curl -X POST https://packages.conary.io:8082/v1/admin/tokens ...)
REMI_ADMIN_TOKEN=

# conary-test server bearer token (any random string, passed to conary-test serve --token)
CONARY_TEST_TOKEN=

# Endpoints
REMI_ENDPOINT=https://packages.conary.io
REMI_ADMIN_ENDPOINT=https://packages.conary.io:8082
FORGE_HOST=peter@forge.conarylabs.com
FORGE_TEST_ENDPOINT=http://forge.conarylabs.com:9090
