# packaging/arch/conary.install
#
# Arch Linux install scriptlet for Conary.

post_install() {
    # Initialize the Conary database and seed default repos (including Remi CCS proxy).
    # Safe to re-run: add_repository checks uniqueness.
    /usr/bin/conary system init 2>/dev/null || true
}

post_upgrade() {
    /usr/bin/conary system init 2>/dev/null || true
}
