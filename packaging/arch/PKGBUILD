# packaging/arch/PKGBUILD
#
# Arch Linux PKGBUILD for Conary.
# Builds from a vendored source tarball (no network access needed during build).

pkgname=conary
pkgver=0.3.1
pkgrel=1
pkgdesc='Modern package manager with atomic operations, rollback, and delta updates'
arch=('x86_64' 'aarch64')
url='https://github.com/ConaryLabs/Conary'
license=('MIT' 'Apache-2.0')
depends=('openssl' 'xz')
makedepends=('cargo' 'pkg-config' 'cmake' 'perl')
options=(!lto)
install=conary.install
source=("$pkgname-$pkgver.tar.gz"
        "vendor.tar.gz")
sha256sums=('SKIP'
            'SKIP')

prepare() {
    cd "$pkgname-$pkgver"

    # Unpack vendored dependencies
    tar xf "$srcdir/vendor.tar.gz"

    mkdir -p .cargo
    cat > .cargo/config.toml <<'EOF'
[source.crates-io]
replace-with = "vendored-sources"

[source.vendored-sources]
directory = "vendor"
EOF
}

build() {
    cd "$pkgname-$pkgver"
    cargo build --release --locked -p conary
}

package() {
    cd "$pkgname-$pkgver"

    # Binary
    install -Dm755 target/release/$pkgname "$pkgdir/usr/bin/$pkgname"

    # Man page
    install -Dm644 man/$pkgname.1 "$pkgdir/usr/share/man/man1/$pkgname.1"

    # Shell completions
    install -d "$pkgdir/usr/share/bash-completion/completions"
    install -d "$pkgdir/usr/share/zsh/site-functions"
    install -d "$pkgdir/usr/share/fish/vendor_completions.d"
    target/release/$pkgname system completions bash > "$pkgdir/usr/share/bash-completion/completions/$pkgname"
    target/release/$pkgname system completions zsh  > "$pkgdir/usr/share/zsh/site-functions/_$pkgname"
    target/release/$pkgname system completions fish > "$pkgdir/usr/share/fish/vendor_completions.d/$pkgname.fish"

    # Licenses
    install -Dm644 LICENSE-MIT "$pkgdir/usr/share/licenses/$pkgname/LICENSE-MIT"
    install -Dm644 LICENSE-APACHE "$pkgdir/usr/share/licenses/$pkgname/LICENSE-APACHE"

    # Config and data directories
    install -d "$pkgdir/etc/$pkgname"
    install -d "$pkgdir/var/lib/$pkgname"
}
