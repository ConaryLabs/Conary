#!/usr/bin/make -f
# packaging/deb/debian/rules

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export CARGO_HOME = $(CURDIR)/.cargo-home

%:
	dh $@

override_dh_auto_configure:
	mkdir -p .cargo
	printf '[source.crates-io]\nreplace-with = "vendored-sources"\n\n[source.vendored-sources]\ndirectory = "vendor"\n' > .cargo/config.toml

override_dh_auto_build:
	cargo build --release --locked -p conary

override_dh_auto_test:
	# Tests require network and a full dev environment; skip in package build
	true

override_dh_auto_install:
	# Binary
	install -Dpm 0755 target/release/conary debian/conary/usr/bin/conary

	# Man page
	install -Dpm 0644 man/conary.1 debian/conary/usr/share/man/man1/conary.1

	# Shell completions
	install -d debian/conary/usr/share/bash-completion/completions
	install -d debian/conary/usr/share/zsh/vendor-functions
	install -d debian/conary/usr/share/fish/vendor_completions.d
	target/release/conary system completions bash > debian/conary/usr/share/bash-completion/completions/conary
	target/release/conary system completions zsh  > debian/conary/usr/share/zsh/vendor-functions/_conary
	target/release/conary system completions fish > debian/conary/usr/share/fish/vendor_completions.d/conary.fish

	# License files
	install -Dpm 0644 LICENSE-MIT debian/conary/usr/share/doc/conary/LICENSE-MIT
	install -Dpm 0644 LICENSE-APACHE debian/conary/usr/share/doc/conary/LICENSE-APACHE

override_dh_auto_clean:
	cargo clean 2>/dev/null || true
	rm -rf .cargo .cargo-home

# dh_clean removes .orig files tree-wide, which breaks vendored crate checksums
override_dh_clean:
	dh_clean -Xvendor/

# No autotools in this project; skip autoreconf to prevent .orig files in vendor/
override_dh_autoreconf:
override_dh_autoreconf_clean:

# Cargo release profile already strips the binary
override_dh_dwz:
override_dh_strip:
